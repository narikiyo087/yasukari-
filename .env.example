# S3 upload configuration for bike model images

# === Credentials ===
# If the runtime is using an IAM role (EC2, Lambda, ECS, etc.),
# credentials are resolved automatically and the following keys can stay empty.
# Uncomment and fill these only when using long-lived IAM user keys or local development profiles.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# === Target bucket and region ===
# Region defaults to ap-northeast-1 if unset.
AWS_REGION=ap-northeast-1
# Bucket name and prefix for storing uploaded bike model images.
BIKE_MODELS_BUCKET=yasukari-file
BIKE_MODELS_PREFIX=BikeModels/

# === Cognito Hosted UI (frontend) ===
# Hosted UI ドメイン・クライアントID・コールバックURLを Next.js から参照します。
NEXT_PUBLIC_COGNITO_DOMAIN=https://ap-northeast-17pdere9jo.auth.ap-northeast-1.amazoncognito.com
NEXT_PUBLIC_COGNITO_CLIENT_ID=vicsspgv2q7mtn6m6os2n893j
NEXT_PUBLIC_COGNITO_REDIRECT_URI=https://yasukaribike.com/auth/callback

# === Pay.JP (frontend sample) ===
# 公開鍵を設定すると、決済画面のサンプルに反映されます。
# NEXT_PUBLIC_PAYJP_PUBLIC_KEY=pk_live_your_public_key
# NEXT_PUBLIC_PAYJP_PUBLIC_KEY_TEST=pk_test_your_public_key

# === Pay.JP (server-side) ===
# 秘密鍵はAPIサーバでのみ使用します。
# PAYJP_SECRET_KEY=sk_live_your_secret_key
# PAYJP_SECRET_KEY_TEST=sk_test_your_secret_key

# === SMTP (server-side) ===
# メール送信に使用するSMTPサーバーのサンプル設定です。
# SMTP_HOST=sv16395.xserver.jp
# SMTP_PORT=587
# SMTP_USER=info@yasukaribike.com
# SMTP_PASS=your-password
# MAIL_FROM="ヤスカリ <info@yasukaribike.com>"

# === KEYBOX (server-side) ===
# 無人店舗の鍵発行APIに必要なキーを設定します。
# export KEYBOX_API_KEY="sample-api-key"
# export KEYBOX_SECRET_KEY="sample-secret-key"
# export KEYBOX_UNIT_ID_OVERRIDE="65ba13340cc4545240154f6c" # 環境未設定時は自動でランダムIDを生成
# export KEYBOX_BASE_URL="https://eco.blockchainlock.io"
# KEYBOX_LOG_TABLE=keyboxExecutionLogs
